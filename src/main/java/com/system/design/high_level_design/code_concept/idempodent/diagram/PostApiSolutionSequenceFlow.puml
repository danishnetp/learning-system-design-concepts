@startuml PostApiSolutionSequenceFlow

title Idempotent POST Solution - Flow Diagram (Sequence / Retry Case)

skinparam backgroundColor #FAFAFA
skinparam ArrowColor #555555
skinparam NoteBackgroundColor #FFFDE7
skinparam NoteBorderColor #F9A825
skinparam ActivityBorderColor #333333
skinparam ActivityBackgroundColor #DDEEFF
skinparam ActivityDiamondBackgroundColor #FFF2CC
skinparam ActivityDiamondBorderColor #F9A825
skinparam ActivityStartColor #4CAF50
skinparam ActivityEndColor #F44336

start

:Client wants to submit POST /orders;

:Step 1: Generate Idempotent Key\n(UUID v4 e.g. abc-123-def-456);

:Step 2: Set Idempotency-Key in\nRequest Header;

:Step 3: Send POST /orders\nwith Idempotency-Key header;

note right
  POST /orders
  Header: Idempotency-Key: abc-123-def-456
  Body: { item: A, qty: 1 }
end note

if (Step 4: Is Idempotency-Key\nheader present in request?) then (NO)
  #F8CECC:Return HTTP 400 Bad Request\n{error: "Idempotency-Key header required"};
  stop
else (YES)
endif

:Step 5: Lookup Idempotency Key\nin Key Store DB;

if (Key found in DB?) then (YES)
  if (Step 7: Check key status) then (status = CREATED)
    #F8CECC:Return HTTP 409 Conflict\n{error: "Request still in progress,\nplease try again later"};
    stop
  else (status = CONSUMED)
    :Retrieve cached response\nfrom Key Store;
    #D5E8D4:Return HTTP 200 OK\n(cached response)\n{order_id: 401};
    stop
  endif
else (NOT FOUND)
endif

:Step 6: ATOMIC INSERT new key entry\ninto Key Store\nstatus = 'CREATED';

note right
  DB Entry:
  idempotency_key: 'abc-123-def-456'
  status: 'CREATED'
  created_at: now()
end note

:Step 7: Execute Business Logic\nINSERT order into Orders DB\n(item=A, qty=1);

if (Business operation\nsucceeded?) then (NO)
  #F8CECC:Return HTTP 500 Internal Server Error\n{error: "Order creation failed"};
  stop
else (YES)
endif

:Step 8: Update Key Store entry\nstatus = 'CONSUMED'\nstored_response = {order_id: 401};

note right
  DB Entry updated:
  idempotency_key: 'abc-123-def-456'
  status: 'CONSUMED'
  response_body: {order_id: 401}
  status_code: 201
end note

:Step 9: Return HTTP 201 Created\n{order_id: 401};

stop

@enduml

