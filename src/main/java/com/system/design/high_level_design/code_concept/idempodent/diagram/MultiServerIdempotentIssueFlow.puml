@startuml MultiServerIdempotentIssueFlow

title Idempotent POST Issue - Multi-Server Flow Diagram\nIndependent DBs + Replication Lag Cause Duplicate Processing

skinparam backgroundColor #FAFAFA
skinparam ArrowColor #555555
skinparam NoteBackgroundColor #FFFDE7
skinparam NoteBorderColor #F9A825
skinparam ActivityBorderColor #333333
skinparam ActivityBackgroundColor #DDEEFF
skinparam ActivityDiamondBackgroundColor #FFF2CC
skinparam ActivityDiamondBorderColor #F9A825
skinparam ActivityStartColor #4CAF50
skinparam ActivityEndColor #F44336

start

:Client sends POST /orders\nIdempotency-Key: uuid-abc123;

:Load Balancer routes request\nto Server 1;

:Server 1 validates\nIdempotency-Key header;

:Server 1 checks DB1\nfor idempotency key;

if (Key found in DB1?) then (YES)
  :Return cached/previous response;
  stop
else (NO)
endif

:Server 1 inserts key in DB1\nstatus = CREATED;
:Server 1 inserts order into DB1;
:Server 1 updates key in DB1\nstatus = CONSUMED;

note right
  Request was processed by Server 1.
  But only DB1 knows this state now.
end note

:Client does not receive response\n(network timeout / retry triggered);

:DB1 replication to DB2 starts\nasynchronously;

note right
  Replication is slow.
  DB2 may still be stale for seconds/minutes.
end note

if (Did replication reach DB2\nbefore retry?) then (NO)
  :Retry request is sent again\nwith same Idempotency-Key;
  :Load Balancer routes retry\nto Server 2;
  :Server 2 validates header;
  :Server 2 checks DB2\nfor idempotency key;

  if (Key found in DB2?) then (YES)
    :Return previous response;
    stop
  else (NO)
  endif

  #F8CECC:Server 2 incorrectly assumes\nthis is a NEW request;
  :Server 2 inserts same key into DB2\nstatus = CREATED;
  :Server 2 inserts duplicate order into DB2;
  :Server 2 updates key in DB2\nstatus = CONSUMED;
  #F8CECC:Return HTTP 201 Created\nfor duplicate order;

  note right
    DUPLICATE OUTCOME:
    - Server 1 created order_id=701
    - Server 2 created order_id=702
    Root cause: per-server DB state
    + asynchronous replication lag
  end note

  stop
else (YES)
  :Retry reaches Server 2\nafter replication completed;
  :Server 2 reads replicated idempotency state;
  :Return previous response\n(no duplicate created);
  stop
endif

@enduml

