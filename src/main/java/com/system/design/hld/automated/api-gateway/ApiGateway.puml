@startuml ApiGateway

title High-Level Design: API Gateway

skinparam backgroundColor #FAFAFA
skinparam componentStyle rectangle

actor "Mobile Client"  as mobile
actor "Web Client"     as web
actor "Third-Party"    as third

rectangle "API Gateway" as gw #DDEEFF {
    component [SSL Termination]          as ssl
    component [Authentication / AuthZ\n(JWT / OAuth2 / API Key)] as auth
    component [Rate Limiter]             as rl
    component [Request Router /\nPath Rewriting]      as router
    component [Request Aggregator]       as agg
    component [Response Transformer\n(JSON ↔ XML, gRPC ↔ REST)] as transform
    component [Circuit Breaker]          as cb
    component [Logging & Tracing\n(OpenTelemetry)]    as log
    component [Cache]                    as gwcache
}

package "Microservices" {
    component [User Service\n:8001]     as us #D5E8D4
    component [Order Service\n:8002]    as os #D5E8D4
    component [Payment Service\n:8003]  as ps #D5E8D4
    component [Product Service\n:8004]  as prs #D5E8D4
    component [Notification\nService\n:8005] as ns #D5E8D4
}

component "Identity Provider\n(Keycloak / Auth0)" as idp #FFF2CC
component "Service Registry\n(Consul / Eureka)" as sr  #FFF2CC

mobile --> gw : HTTPS
web    --> gw : HTTPS
third  --> gw : HTTPS + API Key

ssl       --> auth
auth      --> idp      : Validate token
auth      --> rl
rl        --> router
router    --> agg
agg       --> cb

cb --> us
cb --> os
cb --> ps
cb --> prs
cb --> ns

router --> sr       : Discover service endpoints

gw ..> log : every request/response

note right of gw
  **API Gateway Responsibilities:**
  1. SSL/TLS termination
  2. Authentication & Authorisation
  3. Rate limiting & throttling
  4. Request routing & load balancing
  5. Protocol translation
  6. Request/response transformation
  7. Caching (response cache)
  8. Circuit breaking
  9. Observability (logs/traces/metrics)
  10. API versioning
end note

note bottom of cb
  If a downstream service is unhealthy,
  Circuit Breaker returns a fallback
  immediately — no cascading failures.
end note

@enduml

