@startuml LoadBalancing

title High-Level Design: Load Balancing

skinparam backgroundColor #FAFAFA
skinparam componentStyle rectangle

actor "Client" as client

rectangle "DNS / Global LB" as dns #DDEEFF

rectangle "Load Balancer\n(Layer 4 / Layer 7)" as lb #DDEEFF {
    component [Health Checker] as hc
    component [Routing Algorithm\n(Round Robin / Least Conn\n/ IP Hash / Weighted)] as algo
}

cloud "Server Pool" {
    node "Server 1" as s1 #D5E8D4
    node "Server 2" as s2 #D5E8D4
    node "Server 3" as s3 #D5E8D4
    node "Server N" as sn #D5E8D4
}

database "Shared Session Store\n(Redis)" as session #FFF2CC
database "Shared DB\n(Primary + Replicas)" as db #FFF2CC

client --> dns   : DNS lookup
dns    --> lb    : Route to region

lb --> s1 : forward
lb --> s2 : forward
lb --> s3 : forward
lb --> sn : forward

hc ..> s1 : ping /health
hc ..> s2 : ping /health
hc ..> s3 : ping /health

s1 --> session : read/write session
s2 --> session : read/write session
s3 --> session : read/write session

s1 --> db
s2 --> db
s3 --> db

note right of lb
  **Algorithms:**
  • Round Robin – equal turn
  • Weighted RR – capacity-aware
  • Least Connections – fewest active
  • IP Hash – sticky sessions
  • Random
end note

note bottom of session
  Sticky sessions OR shared session store
  required when servers are stateless.
end note

note right of db
  **Scaling DB reads:**
  Primary handles writes.
  Read Replicas handle reads.
end note

@enduml

